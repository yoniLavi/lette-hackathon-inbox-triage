# EspoCRM Docker Stack - Local Development Defaults
ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD=admin123
ESPOCRM_SITE_URL=http://localhost:8080

MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=espocrm
MYSQL_USER=espocrm
MYSQL_PASSWORD=espocrm_password

CLAUDE_CODE_USE_BEDROCK=1
AWS_BEARER_TOKEN_BEDROCK=...
AWS_REGION=eu-west-1

# EspoCRM API key for the agent (created by: uv run scripts/create_api_user.py)
ESPOCRM_API_KEY=...

# Frontend
NEXT_PUBLIC_AGENT_URL=http://localhost:8001
ESPOCRM_URL=http://localhost:8080
# ESPOCRM_API_KEY is shared with the agent above
